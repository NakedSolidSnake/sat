.TH SAT_FILE 3 "December 2025" "SAT Library" "SAT Library Manual"
.SH NAME
sat_file \- file I/O operations and file management utilities
.SH SYNOPSIS
.nf
.B #include <sat_file.h>
.PP
.BI "sat_status_t sat_file_open(sat_file_t *" object ", const char *" filename ", sat_file_mode_t " mode );
.BI "sat_status_t sat_file_read(const sat_file_t *" object ", void *" buffer ", uint32_t " size );
.BI "sat_status_t sat_file_readline(const sat_file_t *" object ", void *" buffer ", uint32_t " size );
.BI "sat_status_t sat_file_write(const sat_file_t *" object ", const void *" buffer ", uint32_t " size );
.BI "sat_status_t sat_file_get_size(const sat_file_t *" object ", uint32_t *" size );
.BI "sat_status_t sat_file_exists(const char *" filename );
.BI "sat_status_t sat_file_read_to_buffer(const char *" filename ", void **" buffer ", uint32_t " size );
.BI "sat_status_t sat_file_close(sat_file_t *" object );
.BI "sat_status_t sat_file_copy(const char *" source ", const char *" destination );
.BI "sat_status_t sat_file_move(const char *" source ", const char *" destination );
.BI "sat_status_t sat_file_get_permissions(const char *" filename ", uint32_t *" permissions );
.BI "sat_status_t sat_file_set_permissions(const char *" filename ", uint32_t " permissions );
.BI "sat_status_t sat_file_check_extension(const char *" filename ", const char *" extension );
.BI "sat_status_t sat_file_remove(const char *" filename );
.PP
Link with \fI\-lsat_file\fP.
.fi
.SH DESCRIPTION
The
.B sat_file
module provides file I/O operations and file management helpers using the
.B sat_status_t
status model used across SAT.
.PP
The module supports:
.IP \(bu 2
File opening with read, write, and append modes
.IP \(bu 2
Buffered reading and writing through an explicit file handle
.IP \(bu 2
Line-by-line reading
.IP \(bu 2
File copying and moving with permission preservation
.IP \(bu 2
Permission management
.IP \(bu 2
File existence and extension checks
.IP \(bu 2
Reading file contents into a dynamically allocated buffer
.SS Types
.TP
.B sat_file_mode_t
Enumeration for file access modes:
.RS
.IP \(bu 2
.B sat_file_mode_read
\- Open an existing file for reading
.IP \(bu 2
.B sat_file_mode_write
\- Create or truncate a file for writing
.IP \(bu 2
.B sat_file_mode_append
\- Open or create a file for appending
.RE
.TP
.B sat_file_t
Structure representing an open file handle. Its
.B handle
member stores the internal
.BR FILE * .
.SS Basic File Operations
.TP
.BR sat_file_open ()
Opens a file in the specified mode and initializes the file object.
.RS
.PP
Returns success when the file is opened successfully. In write mode, existing
files are truncated. In append mode, writes are performed at the end of the
file.
.RE
.TP
.BR sat_file_read ()
Reads up to
.I size
bytes from an open file into
.IR buffer .
.RS
.PP
Returns failure when the object, handle, or buffer is invalid, when
.I size
is zero, or when no bytes are read. Reading fewer bytes than requested is not
treated as an error.
.RE
.TP
.BR sat_file_readline ()
Reads a line from the file into
.IR buffer .
.RS
.PP
The buffer is cleared before reading and remains null-terminated. Returns
failure when EOF is reached before a new line is read or when an input error
occurs.
.RE
.TP
.BR sat_file_write ()
Writes
.I size
bytes from
.I buffer
to the file and flushes the handle.
.RS
.PP
Returns failure when the object, handle, or buffer is invalid, when
.I size
is zero, or when fewer bytes are written than requested.
.RE
.TP
.BR sat_file_get_size ()
Obtains the file size in bytes.
.RS
.PP
The size is written to the output pointer passed in
.IR size .
The function seeks to the end of the file, stores the size, and rewinds the
file position to the beginning before returning.
.RE
.TP
.BR sat_file_close ()
Closes the underlying file handle and sets the stored handle to
.BR NULL .
.RS
.PP
Always call this function after a successful
.BR sat_file_open ()
to release resources.
.RE
.SS Utility Functions
.TP
.BR sat_file_exists ()
Checks whether a file can be opened for reading.
.RS
.PP
Returns success only when the file exists and is readable. A file that exists
but cannot be opened for reading still returns failure.
.RE
.TP
.BR sat_file_read_to_buffer ()
Opens a file, allocates a buffer, reads up to
.I size
bytes, and closes the file.
.RS
.PP
The output buffer is allocated with
.BR calloc (3)
using the full file size plus one extra byte, so unread bytes remain zeroed.
The
.I size
argument must be greater than zero. The caller owns the returned buffer and
must release it with
.BR free (3).
.RE
.SS File Management Functions
.TP
.BR sat_file_copy ()
Copies the source file to the destination and then applies the source
permissions to the destination.
.RS
.PP
Returns failure if either file cannot be opened or if permission retrieval or
application fails.
.RE
.TP
.BR sat_file_move ()
Moves a file by copying it to the destination and then removing the source.
.RS
.PP
If copying fails, the implementation attempts to remove the destination path.
This is not a direct rename operation.
.RE
.TP
.BR sat_file_get_permissions ()
Retrieves the file mode using
.BR stat (2)
and stores it in
.IR permissions .
.RE
.TP
.BR sat_file_set_permissions ()
Applies the supplied permission bits using
.BR chmod (2).
.RE
.TP
.BR sat_file_check_extension ()
Checks whether the filename ends with the supplied extension string, without
including the dot in
.IR extension .
The comparison is case-sensitive.
.RE
.TP
.BR sat_file_remove ()
Deletes the file using
.BR remove (3).
.RE
.SH RETURN VALUE
All functions in this module return
.BR sat_status_t .
Use
.BR sat_status_get_result (3)
to test whether the operation succeeded and
.BR sat_status_get_motive (3)
to inspect the failure reason.
.SH EXAMPLES
.SS Basic File Reading
.nf
#include <sat_file.h>
#include <sat_status.h>
#include <stdio.h>

void read_file_example (void)
{
    sat_file_t file;
    char buffer[1024] = {0};
    sat_status_t status = sat_file_open (&file, "data.txt", sat_file_mode_read);

    if (sat_status_get_result (&status) == true)
    {
        status = sat_file_read (&file, buffer, sizeof (buffer) - 1);
        if (sat_status_get_result (&status) == true)
        {
            printf ("Content: %s\\n", buffer);
        }

        sat_file_close (&file);
    }
}
.fi
.SS Line-by-Line Reading
.nf
#include <sat_file.h>
#include <sat_status.h>
#include <stdio.h>

void read_lines_example (void)
{
    sat_file_t file;
    char line[256];
    int line_number = 1;
    sat_status_t status = sat_file_open (&file, "lines.txt", sat_file_mode_read);

    if (sat_status_get_result (&status) == false)
    {
        return;
    }

    while (true)
    {
        status = sat_file_readline (&file, line, sizeof (line));
        if (sat_status_get_result (&status) == false)
        {
            break;
        }

        printf ("Line %d: %s", line_number++, line);
    }

    sat_file_close (&file);
}
.fi
.SS Writing to a File
.nf
#include <sat_file.h>
#include <sat_status.h>
#include <stdio.h>
#include <string.h>

void write_file_example (void)
{
    sat_file_t file;
    sat_status_t status = sat_file_open (&file, "output.txt", sat_file_mode_write);

    if (sat_status_get_result (&status) == true)
    {
        const char *data = "Hello, World!\\n";

        status = sat_file_write (&file, data, strlen (data));
        if (sat_status_get_result (&status) == true)
        {
            printf ("Data written successfully\\n");
        }

        sat_file_close (&file);
    }
}
.fi
.SS Reading to an Allocated Buffer
.nf
#include <sat_file.h>
#include <sat_status.h>
#include <stdio.h>
#include <stdlib.h>

void read_file_buffer_example (void)
{
    void *buffer = NULL;
    sat_status_t status = sat_file_read_to_buffer ("config.json", &buffer, 4096);

    if (sat_status_get_result (&status) == true)
    {
        printf ("File contents:\\n%s\\n", (char *) buffer);
        free (buffer);
    }
}
.fi
.SS Getting File Size
.nf
#include <sat_file.h>
#include <sat_status.h>
#include <stdio.h>

void size_example (const char *filename)
{
    sat_file_t file;
    uint32_t size = 0;
    sat_status_t status = sat_file_open (&file, filename, sat_file_mode_read);

    if (sat_status_get_result (&status) == true)
    {
        status = sat_file_get_size (&file, &size);
        if (sat_status_get_result (&status) == true)
        {
            printf ("File size: %u bytes\\n", size);
        }

        sat_file_close (&file);
    }
}
.fi
.SH NOTES
.IP \(bu 2
All operations use
.B sat_status_t
instead of boolean return values.
.IP \(bu 2
.BR sat_file_read_to_buffer ()
requires a non-zero
.I size
argument.
.IP \(bu 2
.BR sat_file_get_size ()
rewinds the file position to the beginning before returning.
.IP \(bu 2
.BR sat_file_move ()
is implemented as copy plus delete rather than
.BR rename (2).
.IP \(bu 2
Extension matching is case-sensitive.
